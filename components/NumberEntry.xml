<!--
    NumberEntry — display-only overlay for typing a score directly.
    Scoreboard.brs owns all key handling and state; this component
    just renders whatever Scoreboard sets on its fields.
    -->
<component name="NumberEntry" extends="Group">

    <interface>
        <field id="promptText" type="string" value="" onChange="onPromptTextChange" />
        <field id="digits" type="string" value="0" onChange="onDigitsChange" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/NumberEntry.brs" />

    <children>
        <Rectangle
            id="dimBg"
            width="1920"
            height="1080"
            color="0x000000C0" />

        <Label
            id="promptLabel"
            translation="[660, 400]"
            width="600"
            height="60"
            horizAlign="center"
            font="font:LargeBoldSystemFont" />

        <Label
            id="digitsLabel"
            translation="[660, 470]"
            width="600"
            height="120"
            horizAlign="center"
            text="0"
            font="font:LargeSystemFont" />

        <Label
            id="hintLabel"
            translation="[360, 620]"
            width="1200"
            height="40"
            horizAlign="center"
            text="0-9: enter digits   OK: confirm   Back: cancel"
            font="font:SmallSystemFont" />
    </children>
</component>

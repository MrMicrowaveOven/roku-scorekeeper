<!--
    NumberEntry — hidden overlay for typing a score directly,
    e.g. correcting a mis-tracked total. Scoreboard shows/hides this
    and moves key-event focus to it while active.
    -->
<component name="NumberEntry" extends="Group">

    <interface>
        <field id="promptText" type="string" value="" />
        <field id="visible" type="boolean" value="false" alias="dimBg.visible" />
        <field id="confirmedValue" type="integer" alwaysNotify="true" />
        <field id="cancelled" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/NumberEntry.brs" />

    <children>
        <Rectangle
            id="dimBg"
            width="1920"
            height="1080"
            color="0x000000C0"
            visible="false" />

        <Label
            id="promptLabel"
            translation="[660, 400]"
            width="600"
            height="60"
            horizAlign="center"
            font="font:LargeBoldSystemFont" />

        <Label
            id="digitsLabel"
            translation="[660, 470]"
            width="600"
            height="120"
            horizAlign="center"
            text="0"
            font="font:LargeSystemFont" />

        <Label
            id="hintLabel"
            translation="[660, 620]"
            width="600"
            height="40"
            horizAlign="center"
            text="0-9: enter digits   OK: confirm   Back: cancel"
            font="font:SmallSystemFont" />
    </children>
</component>

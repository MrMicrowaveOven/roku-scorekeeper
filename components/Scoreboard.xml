<!--
    Scoreboard — owns all game state and remote-key handling.
    TeamPanel instances are created dynamically based on playerCount.
    -->
<component name="Scoreboard" extends="Group">

    <interface>
        <field id="playerCount" type="integer" value="0" onChange="onPlayerCountChange" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/Scoreboard.brs" />

    <children>
        <Label
            translation="[360, 990]"
            width="1200"
            height="40"
            horizAlign="center"
            id="hintLabel"
            font="font:SmallSystemFont" />

        <!-- Add-player box: always in the tree, shown/hidden via visible field -->
        <Group id="addPlayerBox" visible="false">
            <Rectangle id="addBoxOuter" width="64" height="64" color="0x000000C0" />
            <Rectangle id="addBoxInner" width="58" height="58" color="0x555555FF" translation="[3, 3]" />
            <Label id="addBoxLabel" text="+" width="64" height="64" horizAlign="center" vertAlign="center" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
        </Group>

        <Timer id="repeatDelayTimer" duration="0.5" repeat="false" />
        <Timer id="repeatTimer" duration="0.15" repeat="true" />
        <Timer id="repeatAccelTimer" duration="2.0" repeat="false" />
    </children>
</component>

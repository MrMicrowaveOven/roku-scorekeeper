<!--
    Scoreboard — owns all game state (leftScore, rightScore, which
    team is focused) and all remote-key handling. TeamPanel and
    NumberEntry are purely presentational; they just render fields
    Scoreboard sets on them.
    -->
<component name="Scoreboard" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/Scoreboard.brs" />

    <children>
        <Label
            translation="[660, 40]"
            width="600"
            height="60"
            horizAlign="center"
            text="SCOREKEEPER"
            font="font:LargeBoldSystemFont" />

        <TeamPanel
            id="leftPanel"
            translation="[160, 120]"
            teamName="PLAYER 1" />

        <Label
            translation="[930, 450]"
            width="60"
            height="60"
            horizAlign="center"
            text="-" />

        <TeamPanel
            id="rightPanel"
            translation="[1340, 120]"
            teamName="PLAYER 2" />

        <Label
            translation="[360, 870]"
            width="1200"
            height="40"
            horizAlign="center"
            id="hintLabel"
            text="Up/Down: select round   OK: edit / add   Left/Right: switch   *: rename"
            font="font:SmallSystemFont" />

        <Timer id="repeatDelayTimer" duration="0.5" repeat="false" />
        <Timer id="repeatTimer" duration="0.15" repeat="true" />
        <Timer id="repeatAccelTimer" duration="3.0" repeat="false" />
    </children>
</component>

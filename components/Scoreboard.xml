<!--
    Scoreboard — owns all game state (leftScore, rightScore, which
    team is focused) and all remote-key handling. TeamPanel and
    NumberEntry are purely presentational; they just render fields
    Scoreboard sets on them.
    -->
<component name="Scoreboard" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/Scoreboard.brs" />

    <children>
        <Label
            translation="[660, 60]"
            width="600"
            height="60"
            horizAlign="center"
            text="SCOREKEEPER"
            font="font:LargeBoldSystemFont" />

        <TeamPanel
            id="leftPanel"
            translation="[160, 300]"
            teamName="PLAYER 1" />

        <Label
            translation="[930, 480]"
            width="60"
            height="60"
            horizAlign="center"
            text="-" />

        <TeamPanel
            id="rightPanel"
            translation="[1340, 300]"
            teamName="PLAYER 2" />

        <Label
            translation="[660, 920]"
            width="600"
            height="40"
            horizAlign="center"
            text="Left/Right: switch   Up/Down: +/- 1   OK: set score   *: rename"
            font="font:SmallSystemFont" />

        <NumberEntry
            id="numberEntry"
            visible="false" />
    </children>
</component>

<!--
    TeamPanel — renders a team name, per-round score history, and total.
    Written once, instantiated N times by Scoreboard.
    Exposes "teamName", "score", "roundScores", "panelWidth", etc. as
    public fields. Scoreboard drives all of them; no game logic lives here.
    -->
<component name="TeamPanel" extends="Group">

    <interface>
        <field id="panelWidth" type="integer" value="420" onChange="onPanelWidthChange" />
        <field id="teamName"   type="string"  value=""    onChange="onTeamNameChange" />
        <field id="score"      type="integer" value="0"   onChange="onScoreChange" />
        <field id="roundScores" type="string" value=""    onChange="onRoundScoresChange" />
        <field id="roundOffset" type="integer" value="0" />
        <field id="cursorIndex" type="integer" value="-1" onChange="onCursorIndexChange" />
        <field id="editMode"   type="boolean" value="false" onChange="onEditModeChange" />
        <field id="focused"    type="boolean" value="false" onChange="onFocusedChange" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/TeamPanel.brs" />

    <children>
        <Rectangle
            id="focusRing"
            width="420"
            height="680"
            color="0x00000000" />

        <Label
            id="nameLabel"
            translation="[40, 20]"
            width="340"
            height="50"
            horizAlign="center"
            font="font:LargeBoldSystemFont" />

        <Rectangle
            id="divider1"
            translation="[40, 76]"
            width="340"
            height="2"
            color="0xFFFFFF60" />

        <Group
            id="roundsGroup"
            translation="[40, 86]" />

        <Rectangle
            id="divider2"
            translation="[40, 608]"
            width="340"
            height="2"
            color="0xFFFFFF60" />

        <Label
            id="totalLabel"
            translation="[40, 616]"
            width="340"
            height="56"
            horizAlign="center"
            text="Total: 0"
            font="font:MediumBoldSystemFont" />
    </children>
</component>
